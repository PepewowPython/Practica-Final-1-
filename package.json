{
  "name": "rutas-inseguras-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm start --prefix backend",
    "dev:usa": "node backend/usa-server.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:usa\" \"npm run dev:frontend\"",
    "server": "npm start --prefix backend",
    "server:usa": "node backend/usa-server.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
